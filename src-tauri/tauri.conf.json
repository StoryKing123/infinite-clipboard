{
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devPath": "http://localhost:1420",
        "distDir": "../dist"
    },
    "package": {
        "productName": "infinite-paste",
        "version": "0.0.1"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "shell": {
                "all": false,
                "open": true
            },
            "clipboard": {
                "all": true, 
                "writeText": true,
                "readText": true
            }
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "firengxuan",
            "icon": [
                "icons/icon.icns",
                "icons/icon.ico",
                "icons/icon.png"
            ]
        },
        "security": {
            "csp": null
        },
        "windows": [
            {
                "fullscreen": false,
                "resizable": true,
                "title": "infinite-paste",
                "width": 800,
                "height": 600
            }
        ],
        "systemTray":{
          "iconPath": "icons/icon.png",
          "iconAsTemplate": true
        }
    }
}
